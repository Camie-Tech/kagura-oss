{
  "name": "@kagura-run/core",
  "version": "0.2.1",
  "description": "Kagura AI - Open source agentic test execution engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Camie-Tech/kagura-oss.git",

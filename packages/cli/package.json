{
  "name": "@kagura-run/cli",
  "version": "0.2.0",
  "description": "Kagura AI - Open source CLI for running agentic tests",
  "bin": {
    "kagura": "dist/index.js"
  },
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Camie-Tech/kagura-oss.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "testing",
    "e2e",
    "playwright",
    "ai",
    "automation",
    "qa",
    "cli"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js || true",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js",
    "prepack": "npm run clean && npm run build"
  },
  "files": [
    "src/ui/index.html",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "@kagura-run/core": "^0.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "figlet": "^1.11.0",
    "open": "^11.0.0",
    "ora": "^8.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "name": "@kagura/cli",
  "version": "0.1.0",
  "description": "Kagura AI - Open source CLI for running agentic tests",
  "bin": {
    "kagura": "./dist/index.js"
  },
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Camie-Tech/kagura-app.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "testing",
    "e2e",
    "playwright",
    "ai",
    "automation",
    "qa",
    "cli"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@kagura/core": "workspace:*",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
